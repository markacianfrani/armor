#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="$1"
  local source_dir
  local target

  while [ -L "$source" ]; do
    source_dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    target="$(readlink "$source")"
    case "$target" in
      /*) source="$target" ;;
      *) source="$source_dir/$target" ;;
    esac
  done

  source_dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
  printf '%s/%s\n' "$source_dir" "$(basename "$source")"
}

SELF="$(resolve_script_path "${BASH_SOURCE[0]:-$0}")"
REPO_DIR="$(cd "$(dirname "$SELF")/.." >/dev/null 2>&1 && pwd)"
ARMOR_BIN_DIR="${ARMOR_BIN_DIR:-$HOME/.local/bin}"
ARMOR_LINK="$ARMOR_BIN_DIR/armor"

usage() {
  cat <<'EOF'
usage: armor <command>

commands:
  init    Install the global CLI and link shared config
  update  Pull latest repo changes, then relink shared config
  doctor  Print install and repo diagnostics
EOF
}

path_contains() {
  local dir="$1"
  case ":$PATH:" in
    *":$dir:"*) return 0 ;;
    *) return 1 ;;
  esac
}

is_git_repo() {
  git -C "$REPO_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

init_cli() {
  mkdir -p "$ARMOR_BIN_DIR"

  if [ -e "$ARMOR_LINK" ] && [ ! -L "$ARMOR_LINK" ]; then
    echo "armor init: $ARMOR_LINK exists and is not a symlink" >&2
    echo "move it aside or set ARMOR_BIN_DIR to another directory" >&2
    exit 1
  fi

  if [ -L "$ARMOR_LINK" ] && [ "$(readlink "$ARMOR_LINK")" = "$SELF" ]; then
    echo "armor init: already linked $ARMOR_LINK -> $SELF"
  else
    [ -L "$ARMOR_LINK" ] && rm -f "$ARMOR_LINK"
    ln -s "$SELF" "$ARMOR_LINK"
    echo "armor init: linked $ARMOR_LINK -> $SELF"
  fi

  if ! path_contains "$ARMOR_BIN_DIR"; then
    cat <<EOF

armor init: warning: $ARMOR_BIN_DIR is not on PATH.
Add this to your shell profile:

  export PATH="$ARMOR_BIN_DIR:\$PATH"
EOF
  fi

  "$REPO_DIR/scripts/link-config.sh"
}

update_repo() {
  if ! is_git_repo; then
    echo "armor update: $REPO_DIR is not a git checkout" >&2
    echo "clone from git if you want 'armor update' to pull changes" >&2
    exit 1
  fi

  echo "armor update: pulling latest changes in $REPO_DIR"
  git -C "$REPO_DIR" pull --ff-only
  "$REPO_DIR/scripts/link-config.sh"
}

doctor() {
  echo "armor doctor"
  echo "  repo: $REPO_DIR"
  echo "  bin dir: $ARMOR_BIN_DIR"
  echo "  cli link: $ARMOR_LINK"
  echo "  invoked script: $SELF"
  echo

  if is_git_repo; then
    echo "  git: ok"
    local branch
    branch="$(git -C "$REPO_DIR" branch --show-current 2>/dev/null || true)"
    [ -n "$branch" ] && echo "  git branch: $branch"
    if [ -n "$(git -C "$REPO_DIR" status --porcelain 2>/dev/null || true)" ]; then
      echo "  git status: dirty"
    else
      echo "  git status: clean"
    fi
  else
    echo "  git: not a git checkout"
  fi

  if [ -L "$ARMOR_LINK" ]; then
    local link_target
    link_target="$(readlink "$ARMOR_LINK")"
    echo "  global link: $ARMOR_LINK -> $link_target"
  elif [ -e "$ARMOR_LINK" ]; then
    echo "  global link: $ARMOR_LINK exists but is not a symlink"
  else
    echo "  global link: missing"
  fi

  if command -v armor >/dev/null 2>&1; then
    echo "  PATH armor: $(command -v armor)"
  else
    echo "  PATH armor: not found"
  fi

  if path_contains "$ARMOR_BIN_DIR"; then
    echo "  PATH contains bin dir: yes"
  else
    echo "  PATH contains bin dir: no"
  fi
}

case "${1:-}" in
  init)
    init_cli
    ;;
  update)
    update_repo
    ;;
  doctor)
    doctor
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "armor: unknown command: $1" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
