#!/bin/bash
SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Install deps if needed
if [ ! -d "$SKILL_DIR/node_modules" ]; then
  (cd "$SKILL_DIR" && bun install --frozen-lockfile --silent 2>/dev/null || npm install --silent) >&2
fi

# Prefer bun, fall back to node
if command -v bun &>/dev/null; then
  exec bun run "$SKILL_DIR/src/fetch.ts" "$@"
else
  exec npx tsx "$SKILL_DIR/src/fetch.ts" "$@"
fi
