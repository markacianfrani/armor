#!/bin/bash
# Platform detection and binary selection
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

case "$ARCH" in
  x86_64|amd64) ARCH="x64" ;;
  aarch64|arm64) ARCH="arm64" ;;
esac

BINARY="$(dirname "$0")/bin/web-fetch-${OS}-${ARCH}"

if [ ! -f "$BINARY" ]; then
  echo "Error: No binary found for ${OS}-${ARCH}" >&2
  echo "Available binaries:" >&2
  ls "$(dirname "$0")/bin/" >&2
  exit 1
fi

exec "$BINARY" "$@"
