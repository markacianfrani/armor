{
  "name": "web-fetch-skill",
  "private": true,
  "type": "module",
  "dependencies": {
    "html-to-text": "^9.0.5",
    "turndown": "^7.2.2"
  },
  "scripts": {
    "run": "bun run source/fetch.js",
    "build:linux-x64": "bun build source/fetch.js --compile --target=bun-linux-x64 --outfile=bin/web-fetch-linux-x64",
    "build:linux-arm64": "bun build source/fetch.js --compile --target=bun-linux-arm64 --outfile=bin/web-fetch-linux-arm64",
    "build:darwin-arm64": "bun build source/fetch.js --compile --target=bun-darwin-arm64 --outfile=bin/web-fetch-darwin-arm64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64"
  }
}
