        <mxCell id="43" parent="40" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" value="&lt;b&gt;Every edge needs geometry&lt;/b&gt;&lt;br&gt;Include mxGeometry relative=1 on each edge" vertex="1">
          <mxGeometry height="80" width="190" x="480" y="50" as="geometry" />
