        <mxCell id="42" parent="40" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" value="&lt;b&gt;Generate XML directly&lt;/b&gt;&lt;br&gt;Use native draw.io XML, not Mermaid or CSV" vertex="1">
