        <mxCell id="40" parent="1" style="swimlane;startSize=32;rounded=1;html=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" value="XML rules" vertex="1">
          <mxGeometry height="460" width="700" x="-340" y="380" as="geometry" />
