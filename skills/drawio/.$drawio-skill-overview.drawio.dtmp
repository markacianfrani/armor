        <mxCell id="41" parent="40" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" value="&lt;b&gt;Basic structure&lt;/b&gt;&lt;br&gt;Include root cells 0 and 1&lt;br&gt;All diagram cells normally use parent=1" vertex="1">
          <mxGeometry height="80" width="200" x="20" y="50" as="geometry" />
