        <mxCell id="34" parent="30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" value="&lt;b&gt;Open commands&lt;/b&gt;&lt;br&gt;macOS: open &lt;file&gt;&lt;br&gt;Linux: xdg-open &lt;file&gt;" vertex="1">
