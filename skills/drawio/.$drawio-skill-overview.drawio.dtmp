        </mxCell>
        <mxCell id="11" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Use this skill when&lt;/b&gt;&lt;br&gt;The user asks to create, draw, design, or export a diagram&lt;br&gt;Also triggers on draw.io, drawio, drawoi, and .drawio files" vertex="1">
          <mxGeometry height="90" width="320" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;No format requested&lt;/b&gt;&lt;br&gt;Create a .drawio file and open it" vertex="1">
          <mxGeometry height="70" width="150" x="20" y="160" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Export requested&lt;/b&gt;&lt;br&gt;png, svg, or pdf&quot;" vertex="1">
