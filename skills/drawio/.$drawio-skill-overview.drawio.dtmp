        <mxCell id="44" parent="40" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" value="&lt;b&gt;No XML comments&lt;/b&gt;&lt;br&gt;Comments are forbidden in the output" vertex="1">
