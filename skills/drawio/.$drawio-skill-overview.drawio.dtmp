        <mxCell id="20" parent="1" style="swimlane;startSize=32;rounded=1;html=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" value="Core workflow" vertex="1">
          <mxGeometry height="540" width="520" x="420" y="20" as="geometry" />
        </mxCell>
        <mxCell id="21" parent="20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="&lt;b&gt;1. Generate draw.io XML&lt;/b&gt;&lt;br&gt;Use native mxGraphModel for the requested diagram" vertex="1">
          <mxGeometry height="70" width="160" x="180" y="50" as="geometry" />
        </mxCell>
        <mxCell id="22" parent="20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="&lt;b&gt;2. Write the file&lt;/b&gt;&lt;br&gt;Save a .drawio file in the current working directory" vertex="1">
          <mxGeometry height="70" width="160" x="180" y="150" as="geometry" />
        </mxCell>
        <mxCell id="23" parent="20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="&lt;b&gt;3. Optional post-process&lt;/b&gt;&lt;br&gt;Run @drawio/postprocess if available&lt;br&gt;Skip silently if not" vertex="1">
          <mxGeometry height="70" width="160" x="180" y="250" as="geometry" />
        </mxCell>
        <mxCell id="24" parent="20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="&lt;b&gt;4. Export if needed&lt;/b&gt;&lt;br&gt;Use the CLI with --embed-diagram&lt;br&gt;Delete the source .drawio after successful export" vertex="1">
          <mxGeometry height="80" width="160" x="180" y="350" as="geometry" />
        </mxCell>
        <mxCell id="25" parent="20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="&lt;b&gt;5. Open the result&lt;/b&gt;&lt;br&gt;Open the exported file or the .drawio file&quot;" vertex="1">
          <mxGeometry height="60" width="160" x="180" y="460" as="geometry" />
        </mxCell>
        <mxCell id="30" parent="1" style="swimlane;startSize=32;rounded=1;html=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" value="CLI, filenames, and opening" vertex="1">
          <mxGeometry height="280" width="500" x="980" y="20" as="geometry" />
        </mxCell>
        <mxCell id="31" parent="30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" value="&lt;b&gt;Filename rules&lt;/b&gt;&lt;br&gt;Use lowercase hyphenated names&lt;br&gt;Exports use double extensions like name.drawio.png" vertex="1">
          <mxGeometry height="80" width="210" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="32" parent="30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" value="&lt;b&gt;Locate the CLI&lt;/b&gt;&lt;br&gt;Try which drawio first&lt;br&gt;Fallbacks: macOS app path or Linux drawio" vertex="1">
          <mxGeometry height="80" width="220" x="250" y="50" as="geometry" />
        </mxCell>
        <mxCell id="33" parent="30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" value="&lt;b&gt;Export command&lt;/b&gt;&lt;br&gt;drawio -x -f &lt;format&gt; -e -b 10 -o &lt;output&gt; &lt;input.drawio&gt;" vertex="1">
          <mxGeometry height="90" width="210" x="20" y="150" as="geometry" />
