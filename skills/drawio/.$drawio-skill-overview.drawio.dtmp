        <mxCell id="10" parent="1" style="swimlane;startSize=32;rounded=1;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value="Triggers &amp; format choice" vertex="1">
